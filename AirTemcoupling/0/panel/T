FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    panel_to_airRegion
    {
        type            compressible::turbulentTemperatureCoupledBaffleMixed;
        Tnbr            T;
        kappaMethod     solidThermo;  // 关键：指定从固体热物性读取导热系数
        kappa           none;         // 配合 kappaMethod 使用
        sampleRegion    airRegion;
        samplePatch     airRegion_to_panel;
        value           uniform 300;
}
}


