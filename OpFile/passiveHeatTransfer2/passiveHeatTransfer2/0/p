FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inLet
    {
        type            zeroGradient;
    }
    
    outLet
    {
        type            fixedValue;
        value           uniform 0;
    }
    
    walls
    {
        type            zeroGradient;
    }

    sym 
    {
        type            symmetry;
    }

    slave
    {
        type            zeroGradient;
    }

  
    frontAndBack
    {
        type            empty;
    }
}

