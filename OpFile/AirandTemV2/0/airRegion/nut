FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/airRegion";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inLetAir
    {
        type            calculated;
        value           uniform 0;
    }
    outLetAir
    {
        type            calculated;
        value           uniform 0;
    }
    yFront
    {
        type            calculated;
        value           uniform 0;
    }
    yBack
    {
        type            calculated;
        value           uniform 0;
    }
    groundWall
    {
        type            calculated;
        value           uniform 0;
    }
    topWall
    {
        type            calculated;
        value           uniform 0;
    }
    airRegion_to_panel
    {
        type            nutkWallFunction;
        Cmu             0.09;
        kappa           0.41;
        E               9.8;
        value           uniform 0;
    }
}


