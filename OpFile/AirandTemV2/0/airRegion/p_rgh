FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/airRegion";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions       [ 1 -1 -2 0 0 0 0 ];

internalField   uniform 100000;

boundaryField
{
    inLetAir
    {
        type            totalPressure;
        p0              $internalField;
    }
    outLetAir
    {
        type            totalPressure;
        p0              $internalField;
    }
    yFront
    {
        type            totalPressure;
        p0              $internalField;
    }
    yBack
    {
        type            totalPressure;
        p0              $internalField;
    }
    groundWall
    {
        type            fixedFluxPressure;
        p0              $internalField;
        value           uniform 100000;
    }
    topWall
    {
        type            totalPressure;
        p0              $internalField;
    }
    airRegion_to_panel
    {
        type            fixedFluxPressure;
        p0              $internalField;
        value           uniform 100000;
    }
}


