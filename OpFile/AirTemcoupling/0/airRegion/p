FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 1e5;

boundaryField
{
    inLetAir
    {
        type            calculated;
        value           uniform 100000;
    }
    outLetAir
    {
        type            calculated;
        value           uniform 100000;
    }
    yFrontCyclic
    {
        type            cyclic;
    }
    yBackCyclic
    {
        type            cyclic;
    }
    groundWall
    {
        type            calculated;
        value           uniform 100000;
    }
    topWall
    {
        type            calculated;
        value           uniform 100000;
    }
    airRegion_to_panel
    {
        type            calculated;
        value           uniform 100000;
    }
}


