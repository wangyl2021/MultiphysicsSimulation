FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.0096;

boundaryField
{
    inLet
    {
        type            fixedValue;
        value           uniform 0.0096;
    }
    outLet
    {
        type            zeroGradient;
    }
    walls
    {
        type            kqRWallFunction;
        value           uniform 0.0096;
    }
    
    slave
    {
        type            kqRWallFunction;
        value           uniform 0.0096;
    }

    sym 
    {
        type            symmetry;
    }

    frontAndBack
    {
        type            empty;
    }
}





