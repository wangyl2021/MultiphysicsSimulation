FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/airRegion";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 1 -1 -2 0 0 0 0 ];

internalField   uniform 100000;

boundaryField
{
    inLetAir
    {
        type            calculated;
        value           uniform 100000;
    }
    outLetAir
    {
        type            calculated;
        value           uniform 100000;
    }
    yFront
    {
        type            calculated;
        value           uniform 100000;
    }
    yBack
    {
        type            calculated;
        value           uniform 100000;
    }
    groundWall
    {
        type            calculated;
        value           uniform 100000;
    }
    topWall
    {
        type            calculated;
        value           uniform 100000;
    }
    airRegion_to_panel
    {
        type            calculated;
        value           uniform 100000;
    }
}


