FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(U|T)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-06;
        relTol          0.01;
    }

    "(U|T)Final"
    {
        $U;
        relTol          0;
    }
}



relaxationFactors
{
    equations
    {
        ".*"            1;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
}

